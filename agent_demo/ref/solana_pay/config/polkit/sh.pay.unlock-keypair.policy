    <description>Authorize payment up to $20</description>
    <message>Authentication is required to authorize a payment up to $20</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
