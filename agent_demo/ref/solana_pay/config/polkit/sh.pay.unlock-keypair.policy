    <description>Authorize payment up to $25</description>
    <message>Authentication is required to authorize a payment up to $25</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-50">
    <description>Authorize payment up to $50</description>
    <message>Authentication is required to authorize a payment up to $50</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-above-usd-50">
    <description>Authorize payment above $50</description>
    <message>Authentication is required to authorize a payment above $50</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.create-keypair">
    <description>Create Solana payment account</description>
    <message>Authentication is required to create a Solana payment account</message>
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
  <action id="sh.pay.import-keypair">
    <description>Import Solana payment account</description>
    <message>Authentication is required to import a Solana payment account</message>
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
  <action id="sh.pay.export-keypair">
    <description>Export Solana payment account</description>
    <message>Authentication is required to export a Solana payment account</message>
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
  <action id="sh.pay.delete-keypair">
    <description>Delete Solana payment account</description>
    <message>Authentication is required to delete a Solana payment account</message>
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
  <action id="sh.pay.open-session">
    <description>Open pay session</description>
    <message>Authentication is required to open a pay session</message>
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
  <action id="sh.pay.use-gateway-fee-payer">
    <description>Use gateway fee payer account</description>
    <message>Authentication is required to use your Solana payment account as the gateway fee payer</message>
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
  <action id="sh.pay.use-keypair">
    <description>Use Solana payment account</description>
    <message>Authentication is required to use your Solana payment account</message>
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
  <action id="sh.pay.unlock-keypair">
    <description>Use Solana payment account</description>
    <message>Authentication is required to use your Solana payment account</message>
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
</policyconfig>
