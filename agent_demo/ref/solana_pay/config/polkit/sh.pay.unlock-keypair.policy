    <description>Authorize payment up to $0.50</description>
    <message>Authentication is required to authorize a payment up to $0.50</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-1">
    <description>Authorize payment up to $1</description>
    <message>Authentication is required to authorize a payment up to $1</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-2">
    <description>Authorize payment up to $2</description>
    <message>Authentication is required to authorize a payment up to $2</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
