    <message>Authentication is required to authorize a payment up to $10</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-15">
    <description>Authorize payment up to $15</description>
    <message>Authentication is required to authorize a payment up to $15</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
