<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
 "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/PolicyKit/1.0/policyconfig.dtd">
<policyconfig>
  <vendor>Solana Foundation</vendor>
  <vendor_url>https://solana.org</vendor_url>
  <action id="sh.pay.authorize-payment">
    <description>Authorize Solana payment</description>
    <message>Authentication is required to authorize a Solana payment</message>
    <defaults>
      <!-- auth_self: requires the user's own credentials (password or fingerprint),
           not admin/root. Applies in all contexts. -->
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-00001">
    <description>Authorize payment up to $0.0001</description>
    <message>Authentication is required to authorize a payment up to $0.0001</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-0001">
    <description>Authorize payment up to $0.001</description>
    <message>Authentication is required to authorize a payment up to $0.001</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-0005">
    <description>Authorize payment up to $0.005</description>
    <message>Authentication is required to authorize a payment up to $0.005</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-001">
    <description>Authorize payment up to $0.01</description>
    <message>Authentication is required to authorize a payment up to $0.01</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-005">
    <description>Authorize payment up to $0.05</description>
    <message>Authentication is required to authorize a payment up to $0.05</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
  <action id="sh.pay.authorize-payment-up-to-usd-01">
    <description>Authorize payment up to $0.10</description>
    <message>Authentication is required to authorize a payment up to $0.10</message>
    <defaults><allow_any>auth_self</allow_any><allow_inactive>auth_self</allow_inactive><allow_active>auth_self</allow_active></defaults>
  </action>
