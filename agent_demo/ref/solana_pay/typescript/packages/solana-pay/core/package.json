{
    "name": "@solana/pay",
    "version": "1.0.17",
    "author": "Solana Maintainers <maintainers@solana.foundation>",
    "repository": "https://github.com/solana-foundation/pay",
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=20"
    },
    "bin": {
        "pay": "./run.cjs"
    },
    "files": [
        "dist",
        "src",
        "run.cjs",
        "install.cjs",
        "platform.cjs",
        "skills",
        "LICENSE",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "scripts": {
        "clean": "rm -rf dist *.tsbuildinfo || true",
        "build": "tsup",
        "watch": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "fmt": "prettier --write '{*,**/*}.{ts,tsx,js,jsx,json}' && eslint --fix 'src/**/*.ts'",
        "lint": "prettier --check '{*,**/*}.{ts,tsx,js,jsx,json}' && eslint 'src/**/*.ts'",
        "release": "npm run clean && npm run build"
    },
    "dependencies": {
        "@solana/plugin-interfaces": "^6.9.0",
        "@solana/qr-code-styling": "^1.6.0"
    },
    "peerDependencies": {
        "@solana-program/memo": "^0.11.0",
        "@solana-program/system": "^0.12.0",
        "@solana-program/token": "^0.12.0",
        "@solana-program/token-2022": "^0.9.0",
        "@solana/keys": "^6.9.0",
        "@solana/kit": "^6.9.0",
        "@solana/kit-plugin-instruction-plan": "^0.10.0",
        "@solana/kit-plugin-rpc": "^0.11.1",
        "@solana/kit-plugin-signer": "^0.10.0",
        "@solana/rpc-subscriptions-api": "^6.9.0",
        "@solana/rpc-subscriptions-spec": "^6.9.0"
    },
    "preferUnplugged": true,
    "supportedPlatforms": {
        "aarch64-apple-darwin": {
            "artifact": "pay-aarch64-apple-darwin.tar.gz",
            "binary": "pay"
        },
        "x86_64-apple-darwin": {
            "artifact": "pay-x86_64-apple-darwin.tar.gz",
            "binary": "pay"
        },
        "aarch64-unknown-linux-gnu": {
            "artifact": "pay-aarch64-unknown-linux-gnu.tar.gz",
            "binary": "pay"
        },
        "aarch64-unknown-linux-musl": {
            "artifact": "pay-aarch64-unknown-linux-musl.tar.gz",
            "binary": "pay"
        },
        "x86_64-unknown-linux-gnu": {
            "artifact": "pay-x86_64-unknown-linux-gnu.tar.gz",
            "binary": "pay"
        },
        "x86_64-unknown-linux-musl": {
            "artifact": "pay-x86_64-unknown-linux-musl.tar.gz",
            "binary": "pay"
        },
        "x86_64-pc-windows-msvc": {
            "artifact": "pay-x86_64-pc-windows-msvc.zip",
            "binary": "pay.exe"
        }
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@solana-program/memo": "^0.11.0",
        "@solana-program/system": "^0.12.0",
        "@solana-program/token": "^0.12.0",
        "@solana-program/token-2022": "^0.9.0",
        "@solana/eslint-config-solana": "^6.0.0",
        "@solana/keys": "^6.9.0",
        "@solana/kit": "^6.9.0",
        "@solana/kit-plugin-instruction-plan": "^0.10.0",
        "@solana/kit-plugin-litesvm": "^0.10.0",
        "@solana/kit-plugin-rpc": "^0.11.1",
        "@solana/kit-plugin-signer": "^0.10.0",
        "@solana/prettier-config-solana": "^0.0.6",
        "@solana/rpc-subscriptions-api": "^6.9.0",
        "@solana/rpc-subscriptions-spec": "^6.9.0",
        "@types/node": "^20.0.0",
        "@vitest/coverage-v8": "^4.1.2",
        "eslint": "^9.39.1",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-sort-keys-fix": "^1.1.2",
        "eslint-plugin-typescript-sort-keys": "^3.3.0",
        "globals": "^16.5.0",
        "prettier": "^3.8.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.49.0",
        "vitest": "^4.0.18"
    }
}
